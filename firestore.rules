rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }
    
    match /workspaces/{workspaceId} {
      allow read: if true;
      allow write: if isAuthenticated();
      match /bases/{baseId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /campaigns/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /content_calendar/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /lead_pipeline/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /budget_tracker/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /boards/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /projects/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
