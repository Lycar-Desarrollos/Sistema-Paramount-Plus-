rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isWorkspaceMember(workspaceId) {
      let ws = get(/databases/$(database)/documents/workspaces/$(workspaceId));
      return isAuthenticated() && (
        ws.data.members == null || 
        ws.data.members[request.auth.uid] != null
      );
    }

    function getWorkspaceRole(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.members[request.auth.uid];
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /workspaces/{workspaceId} {
      allow read: if true;
      allow write: if isAuthenticated();
      match /bases/{baseId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /campaigns/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /content_calendar/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /lead_pipeline/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /budget_tracker/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /boards/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /projects/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
