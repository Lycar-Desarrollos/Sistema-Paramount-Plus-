rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isAuthenticated() && request.auth.uid == "RXH1eN22BtUAdJBrK4bPR3AxiO52";
    }

    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && exists(userPath) && get(userPath).data.get('role', '') == 'admin';
    }

    // ── Usuarios ──
    // Solo admins pueden listar y modificar todos los usuarios.
    // Un colaborador solo puede leer y actualizar su propio documento (ej. foto de perfil).
    match /users/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || isMasterAdmin() || request.auth.uid == userId);
      allow write: if isAuthenticated() && (isAdmin() || isMasterAdmin() || request.auth.uid == userId);
    }

    // ── Workspaces / Proyectos ──
    match /workspaces/{workspaceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        isMasterAdmin() ||
        request.auth.uid == resource.data.get('ownerId', '') ||
        request.auth.token.get('email', '').lower() in resource.data.get('memberEmails', [])
      );
      allow delete: if isAuthenticated() && (isAdmin() || isMasterAdmin() || request.auth.uid == resource.data.get('ownerId', ''));
    }

    // ── Tablas ──
    match /tables/{tableId} {
      allow read: if isAuthenticated();
      // Sin auth: solo tablas públicas de tipo 'requests' (formulario para clientes)
      allow read: if !isAuthenticated() && resource.data.get('type', '') == 'requests';
      allow write: if isAuthenticated();
    }

    // ── Registros (campaigns) ──
    match /campaigns/{docId} {
      allow read, write: if isAuthenticated();
      // Formulario público sin login
      allow create: if !isAuthenticated() &&
        request.resource.data.get('source', '') == 'public_form';
    }
  }
}
